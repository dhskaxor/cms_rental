<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nt.cms.file.mapper.FileMapper">

    <!-- 파일 ResultMap -->
    <resultMap id="FileResultMap" type="com.nt.cms.file.vo.FileVO">
        <id property="id" column="id"/>
        <result property="refType" column="ref_type"/>
        <result property="refId" column="ref_id"/>
        <result property="originalName" column="original_name"/>
        <result property="storedName" column="stored_name"/>
        <result property="filePath" column="file_path"/>
        <result property="fileSize" column="file_size"/>
        <result property="mimeType" column="mime_type"/>
        <result property="createdAt" column="created_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <!-- ID로 파일 조회 -->
    <select id="findById" resultMap="FileResultMap">
        SELECT
            id,
            ref_type,
            ref_id,
            original_name,
            stored_name,
            file_path,
            file_size,
            mime_type,
            created_at,
            deleted
        FROM file
        WHERE id = #{id}
          AND deleted = 0
    </select>

    <!-- ref_type, ref_id로 파일 목록 조회 -->
    <select id="findByRef" resultMap="FileResultMap">
        SELECT
            id,
            ref_type,
            ref_id,
            original_name,
            stored_name,
            file_path,
            file_size,
            mime_type,
            created_at,
            deleted
        FROM file
        WHERE ref_type = #{refType}
          AND ref_id = #{refId}
          AND deleted = 0
        ORDER BY id ASC
    </select>

    <!-- 파일 등록 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO file (
            ref_type,
            ref_id,
            original_name,
            stored_name,
            file_path,
            file_size,
            mime_type,
            created_at,
            deleted
        ) VALUES (
            #{refType},
            #{refId},
            #{originalName},
            #{storedName},
            #{filePath},
            #{fileSize},
            #{mimeType},
            NOW(),
            0
        )
    </insert>

    <!-- 파일 삭제 (Soft Delete) -->
    <update id="delete">
        UPDATE file
        SET deleted = 1
        WHERE id = #{id}
          AND deleted = 0
    </update>

    <!-- ref_type, ref_id로 파일 개수 조회 -->
    <select id="countByRef" resultType="long">
        SELECT COUNT(*)
        FROM file
        WHERE ref_type = #{refType}
          AND ref_id = #{refId}
          AND deleted = 0
    </select>

    <!-- 관리자용 파일 검색 where 조건 -->
    <sql id="fileSearchWhere">
        <where>
            deleted = 0
            <if test="request.refType != null and request.refType != ''">
                AND ref_type = #{request.refType}
            </if>
            <if test="request.refId != null">
                AND ref_id = #{request.refId}
            </if>
        </where>
    </sql>

    <!-- 관리자용 파일 목록 조회 -->
    <select id="findAllWithFilter" resultMap="FileResultMap">
        SELECT
            id,
            ref_type,
            ref_id,
            original_name,
            stored_name,
            file_path,
            file_size,
            mime_type,
            created_at,
            deleted
        FROM file
        <include refid="fileSearchWhere"/>
        ORDER BY id DESC
        LIMIT #{request.size} OFFSET #{request.offset}
    </select>

    <!-- 관리자용 파일 개수 조회 -->
    <select id="countWithFilter" resultType="long">
        SELECT COUNT(*)
        FROM file
        <include refid="fileSearchWhere"/>
    </select>

    <!-- ref_id 갱신 (에디터 인라인 이미지 → 게시글 연결) -->
    <update id="updateRefId">
        UPDATE file
        SET ref_id = #{refId}
        WHERE id = #{id}
          AND deleted = 0
          AND ref_type = 'POST'
    </update>
</mapper>
