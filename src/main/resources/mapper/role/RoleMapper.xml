<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nt.cms.role.mapper.RoleMapper">

    <!-- 역할 ResultMap -->
    <resultMap id="RoleResultMap" type="com.nt.cms.role.vo.RoleVO">
        <id property="id" column="id"/>
        <result property="roleCode" column="role_code"/>
        <result property="roleName" column="role_name"/>
        <result property="description" column="description"/>
        <result property="userCount" column="user_count"/>
        <result property="createdAt" column="created_at"/>
        <result property="createdBy" column="created_by"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="updatedBy" column="updated_by"/>
        <result property="deleted" column="deleted"/>
        <collection property="permissions" ofType="com.nt.cms.role.vo.PermissionVO">
            <id property="id" column="perm_id"/>
            <result property="permissionCode" column="permission_code"/>
            <result property="permissionName" column="permission_name"/>
            <result property="description" column="perm_description"/>
        </collection>
    </resultMap>

    <!-- 역할 단순 ResultMap (권한 없이) -->
    <resultMap id="RoleSimpleResultMap" type="com.nt.cms.role.vo.RoleVO">
        <id property="id" column="id"/>
        <result property="roleCode" column="role_code"/>
        <result property="roleName" column="role_name"/>
        <result property="description" column="description"/>
        <result property="userCount" column="user_count"/>
        <result property="createdAt" column="created_at"/>
        <result property="createdBy" column="created_by"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="updatedBy" column="updated_by"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <!-- 역할 목록 조회 (권한 포함) -->
    <select id="findAll" resultMap="RoleSimpleResultMap">
        SELECT
            r.id,
            r.role_code,
            r.role_name,
            r.description,
            r.created_at,
            r.created_by,
            r.updated_at,
            r.updated_by,
            r.deleted,
            (SELECT COUNT(*) FROM user u WHERE u.role_id = r.id AND u.deleted = 0) AS user_count
        FROM role r
        WHERE r.deleted = 0
        ORDER BY r.id ASC
    </select>

    <!-- ID로 역할 조회 (권한 포함) -->
    <select id="findById" resultMap="RoleResultMap">
        SELECT
            r.id,
            r.role_code,
            r.role_name,
            r.description,
            r.created_at,
            r.created_by,
            r.updated_at,
            r.updated_by,
            r.deleted,
            (SELECT COUNT(*) FROM user u WHERE u.role_id = r.id AND u.deleted = 0) AS user_count,
            p.id AS perm_id,
            p.permission_code,
            p.permission_name,
            p.description AS perm_description
        FROM role r
        LEFT JOIN role_permission rp ON r.id = rp.role_id
        LEFT JOIN permission p ON rp.permission_id = p.id AND p.deleted = 0
        WHERE r.id = #{id}
          AND r.deleted = 0
    </select>

    <!-- 역할 코드로 조회 -->
    <select id="findByRoleCode" resultMap="RoleSimpleResultMap">
        SELECT
            r.id,
            r.role_code,
            r.role_name,
            r.description,
            r.created_at,
            r.created_by,
            r.updated_at,
            r.updated_by,
            r.deleted,
            (SELECT COUNT(*) FROM user u WHERE u.role_id = r.id AND u.deleted = 0) AS user_count
        FROM role r
        WHERE r.role_code = #{roleCode}
          AND r.deleted = 0
    </select>

    <!-- 역할 코드 존재 여부 -->
    <select id="existsByRoleCode" resultType="boolean">
        SELECT EXISTS(
            SELECT 1 FROM role
            WHERE role_code = #{roleCode}
              AND deleted = 0
        )
    </select>

    <!-- 역할 등록 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO role (
            role_code,
            role_name,
            description,
            created_at,
            created_by,
            deleted
        ) VALUES (
            #{roleCode},
            #{roleName},
            #{description},
            NOW(),
            #{createdBy},
            0
        )
    </insert>

    <!-- 역할 수정 -->
    <update id="update">
        UPDATE role
        SET
            role_name = #{roleName},
            description = #{description},
            updated_at = NOW(),
            updated_by = #{updatedBy}
        WHERE id = #{id}
          AND deleted = 0
    </update>

    <!-- 역할 삭제 (Soft Delete) -->
    <update id="delete">
        UPDATE role
        SET
            deleted = 1,
            updated_at = NOW(),
            updated_by = #{deletedBy}
        WHERE id = #{id}
          AND deleted = 0
    </update>

    <!-- 역할-권한 매핑 삭제 -->
    <delete id="deleteRolePermissions">
        DELETE FROM role_permission
        WHERE role_id = #{roleId}
    </delete>

    <!-- 역할-권한 매핑 등록 -->
    <insert id="insertRolePermission">
        INSERT INTO role_permission (role_id, permission_id)
        VALUES (#{roleId}, #{permissionId})
    </insert>

    <!-- 역할별 권한 ID 목록 조회 -->
    <select id="findPermissionIdsByRoleId" resultType="long">
        SELECT permission_id
        FROM role_permission
        WHERE role_id = #{roleId}
    </select>

</mapper>
