# ==============================================
# CMS Core Platform - Git 무시 파일
# ==============================================

# Gradle
.gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# IDE - IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# IDE - Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
bin/

# IDE - VS Code
.vscode/

# IDE - NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# OS 생성 파일
.DS_Store
Thumbs.db

# 로그 파일
*.log
logs/

# 패키지 파일
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
# Gradle wrapper jar는 제외 (CI 빌드에 필수)
!gradle/wrapper/gradle-wrapper.jar

# 가상 머신 충돌 로그
hs_err_pid*
replay_pid*

# 프로젝트 설정 파일 (민감 정보 포함 가능)
cms-config.yml

# 업로드 파일 디렉토리
uploads/

# 테스트 생성 파일
build/test-files/

# 환경 변수 파일
.env
.env.local
.env.*.local

# Lombok
.lombok/
